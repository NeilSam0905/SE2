# Supabase Configuration
# Get these values from your Supabase project settings

# Your Supabase URL (found in Project Settings > API)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase Public Anon Key (found in Project Settings > API > Project API keys)
VITE_SUPABASE_ANON_KEY=your-publishable-api-key

# Example values:
# VITE_SUPABASE_URL=https://ovucquikswfdlexjrdai.supabase.co
# VITE_SUPABASE_ANON_KEY=sb_publishable_nF5salrKZJQ65fbCHNPagw_ppqKXY3N
